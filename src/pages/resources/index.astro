---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const resourceModules = import.meta.glob("../../content/resources/*.md", { eager: true });

const resources = Object.entries(resourceModules)
  .map(([path, module]) => {
    const typedModule = module as {
      frontmatter: {
        title: string;
        description?: string;
        date?: string;
        category?: string;
        tags?: string[];
        featured?: boolean;
      };
    };
    const slug = path.split("/").pop()?.replace(".md", "") ?? "";

    return {
      slug,
      ...typedModule.frontmatter
    };
  })
  .sort((a, b) => {
    const dateA = new Date(a.date ?? "1970-01-01").getTime();
    const dateB = new Date(b.date ?? "1970-01-01").getTime();
    return dateB - dateA;
  });
---

<BaseLayout
  title="News and Resources | Ruijie Machinery"
  description="News, technical resources and project guides for smart precast beam factory and smart girder yard planning."
  canonical="/resources/"
>
  <Header />
  <main class="simple-page">
    <section class="container">
      <p class="eyebrow">News & Resources</p>
      <h1>Smart girder yard insights for project planning</h1>
      <p>
        This page is prepared as the Markdown-friendly content entrance. Future articles can be maintained as individual resource pages and linked back to Solution, Equipment and RFQ.
      </p>
      <div class="resource-list">
        {resources.map((item) => (
          <article>
            <span>{item.category ?? "Resource"}{item.featured ? " / Featured" : ""}</span>
            <h2>
              <a href={`/resources/${item.slug}/`}>{item.title}</a>
            </h2>
            {item.date && <time datetime={item.date}>{item.date}</time>}
            <p>{item.description}</p>
            {item.tags && item.tags.length > 0 && (
              <div class="tag-list">
                {item.tags.map((tag) => <span>{tag}</span>)}
              </div>
            )}
            <a class="text-link" href={`/resources/${item.slug}/`}>Read article</a>
          </article>
        ))}
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
